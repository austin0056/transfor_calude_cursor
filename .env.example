# 服务监听端口,Zeabur 会自动注入 PORT
PORT=8080

# PostgreSQL 连接串,Zeabur 里用变量引用 ${POSTGRES_CONNECTION_STRING}
DATABASE_URL=postgres://user:password@host:5432/dbname

# 上游 Anthropic 兼容 API
UPSTREAM_BASE_URL=https://xcapi.top
UPSTREAM_API_KEY=your-upstream-api-key-here
UPSTREAM_MODEL=claude-opus-4-7

# 对外暴露给 Cursor 的模型名(可与上游一致)
EXPOSED_MODEL=claude-opus-4-7

# 管理面板登录密码
ADMIN_PASSWORD=change-me-please

# 用于签发管理面板 session cookie 的密钥,随便一段长字符串
SESSION_SECRET=please-change-this-to-a-random-string
